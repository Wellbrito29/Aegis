{
  "schema-version": 1,
  "aegis-version": "{{VERSION}}",
  "installed-at": "{{INSTALLED_AT}}",
  "project-name": "{{PROJECT_NAME}}",
  "prefix-format": "sequencial",
  "language": "pt-BR",
  "watch": {
    "archive-after": 3,
    "block-on-red": false
  },
  "paths": {
    "sdd-dir": "aegis/specs/sdd",
    "forward-dir": "aegis/forward",
    "config-dir": "aegis/config"
  },
  "principles": {
    "enabled": true,
    "auto-load-into-plan": true
  },
  "telemetry": {
    "enabled": false
  }
}
